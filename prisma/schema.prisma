generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid()) // Will store the Clerk User ID
  email     String   @unique
  role      String   @default("user") // "user" or "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Product {
  id               String   @id @default(cuid())
  name             String
  description      String
  price            Float
  discountPrice    Float?
  category         String   // "capilares_corporales" or "joyas"
  images           String[]
  specifications   Json?    
  shippingDetails  String?
  deliveryMethod   String?
  pickupPoints     String[]
  stock            Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orderItems       OrderItem[]
  clicks           ProductClick[]
  inventoryChanges InventoryChange[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  customerName String?
  customerPhone String?
  total     Float
  status    String      @default("pending") // "pending", "whatsapp_sent", "completed"
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model StoreSettings {
  id                 String   @id @default("global")
  heroBannerUrl      String?  
  bannerIsActive     Boolean  @default(false)
  storeNotice        String?  
  whatsappNumber     String   @default("56930531304")
  updatedAt          DateTime @updatedAt
}

model PageView {
  id        String   @id @default(cuid())
  path      String?
  createdAt DateTime @default(now())
}

model ProductClick {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model InventoryChange {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  previousStock Int
  newStock      Int
  change        Int
  reason        String   // "MANUAL_UPDATE", "SALE", "RESTOCK"
  createdAt     DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  
  userEmail   String?  
  action      String   // "CREATE_PRODUCT", "UPDATE_PRICE", "UPDATE_STOCK", "DELETE_PRODUCT", "UPDATE_SETTINGS", "UPDATE_ROLE", "UPDATE_DISCOUNT", "CONFIRM_ORDER", "CANCEL_ORDER"
  entityType  String   // "PRODUCT", "ORDER", "USER", "SETTINGS"
  entityName  String?  // Ej. "Crema facial" o "luciano@gmail.com"
  details     String?  // Detalles descriptivos, ej. "De $1000 a $2000"
  createdAt   DateTime @default(now())
}
